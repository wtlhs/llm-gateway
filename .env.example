# ===== 监听与上游 =====
LISTEN_ADDR=:8080
NEW_API_BASE_URL=http://newapi.internal:3000
# 上游是否 HTTPS; 若 true 则 Transport 启用 TLS
NEW_API_TLS=false

# ===== 双库 =====
# 读写库: 沉淀数据
CONTEXT_DB_URL=postgres://ctx:ctx@localhost:5432/context_repo?sslmode=disable
# 只读库: 反查 New API token 映射
NEWAPI_DB_URL=postgres://ro:ro@localhost:5432/new-api?sslmode=disable

# ===== 审计 =====
# full=原文落库; redact=脱敏后落库; off=不落库(仅透传)
LLM_AUDIT_MODE=redact
# 逗号分隔, 不捕获的模型名
LLM_AUDIT_EXCLUDE_MODELS=
# 仅这些端点走捕获逻辑(A/B类). C/D类(images/audio/models/realtime)自动 bypass
LLM_AUDIT_CAPTURE_ENDPOINTS=chat/completions,completions,responses,embeddings,moderations
# 解压后单条上限(字节)
LLM_AUDIT_MAX_BODY_BYTES=65536
# 解压前上限(字节), 防解压炸弹, 对齐 New API 32MB
LLM_AUDIT_PRE_BODY_MAX_BYTES=33554432
# 留存期(天) - 需法务/安全评审确认
LLM_AUDIT_TTL_DAYS=90

# ===== 过载保护 =====
# 连续建连失败多少次熔断
BREAKER_FAILURES=5
# 稳态 req/s per Bearer token
RATE_PER_CALLER=50
# 突发桶大小
RATE_BURST=100
# 无 Authorization 的匿名桶 req/s
RATE_ANON=10

# ===== 性能 =====
CAPTURE_CHANNEL_SIZE=4096
DB_MAX_OPEN_CONNS=25
WORKER_POOL_SIZE=8
SHUTDOWN_TIMEOUT_SEC=30
DRAIN_TIMEOUT_SEC=20

# ===== caller 反查 =====
CALLER_CACHE_REFRESH_SEC=60

# ===== 安全(见 DESIGN.md §9) =====
# /metrics 的 bearer; 空则仅内网 IP 可访问管理端点
METRICS_AUTH_TOKEN=
# /ctx/* 的 bearer
ADMIN_AUTH_TOKEN=
# slog 字段黑名单(逗号分隔), 命中则替换为 <redacted>
SLOG_PROMPT_FIELDS_BLOCKLIST=request.body,response.body,prompt_text,completion_text

# ===== 日志 =====
LOG_LEVEL=info
